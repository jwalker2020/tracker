# =============================================================================
# Local development (copy to .env.local, use localhost)
# =============================================================================

# PocketBase URL (required for GPX upload, list, file serving, enrichment)
NEXT_PUBLIC_PB_URL=http://localhost:8090

# Optional: dev-only user id when no auth cookie is set. Do not use in production.
# GUEST_USER_ID=

# DEM elevation enrichment (optional). If unset, enrichment is skipped with a warning.
# Absolute path to folder containing DEM GeoTIFF tiles and manifest.json
# DEM_BASE_PATH=/path/to/dem
# DEM_MANIFEST_PATH=manifest.json

# Optional: Stadia Maps API key for premium tiles (see MapView)
# NEXT_PUBLIC_STADIA_MAPS_API_KEY=

# =============================================================================
# Production (set in host env or .env.production.local; do not use localhost)
# =============================================================================
# NEXT_PUBLIC_PB_URL=https://pb.yourdomain.com
# DEM_BASE_PATH=/app/data/dem
# DEM_MANIFEST_PATH=manifest.json
# DISABLE_WEB_ENRICHMENT_RESUME=true
# ENABLE_ENRICHMENT_WORKER=true
# ENRICHMENT_WORKER_POLL_INTERVAL_MS=5000
