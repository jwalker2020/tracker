# PocketBase (required for GPX upload/list)
NEXT_PUBLIC_PB_URL=http://localhost:8090

# DEM elevation enrichment (optional)
# Absolute path to folder containing DEM GeoTIFF tiles and manifest.json.
# If unset, elevation enrichment is skipped and uploads still succeed with a warning.
# DEM_BASE_PATH=/path/to/dem

# Optional: path to manifest file (relative to DEM_BASE_PATH or absolute).
# Default is manifest.json inside DEM_BASE_PATH.
# DEM_MANIFEST_PATH=manifest.json
