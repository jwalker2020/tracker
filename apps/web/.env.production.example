# Production environment example. Set these in your host (e.g. Vercel, Docker, systemd).
# Do not commit real secrets. Do not use localhost in production.
# Async enrichment runs in the worker.

# PocketBase URL (required). Use your deployed PocketBase or API URL.
NEXT_PUBLIC_PB_URL=https://pb.yourdomain.com

# DEM elevation enrichment (optional). Path valid inside the worker container.
DEM_BASE_PATH=/app/data/dem
DEM_MANIFEST_PATH=manifest.json

# Worker container: poll interval when no job is available (milliseconds).
# ENRICHMENT_WORKER_POLL_INTERVAL_MS=5000

# Optional: Stadia Maps API key for premium basemap tiles.
# NEXT_PUBLIC_STADIA_MAPS_API_KEY=
